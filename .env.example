# =========================================================
# TripSketch AI — Environment Variables
# =========================================================
# Copy this file to .env and fill in your keys.
#   cp .env.example .env

# --- Anthropic Claude API (required for "claude" generation mode) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Google Maps Places API (optional, for live place lookup) -------
# GOOGLE_MAPS_API_KEY=your-google-maps-key
# PLACES_MODE=mock          # "mock" or "live"
